{
  "manifest_version": 3,
  "name": "쉬운 기기 테스트",
  "description": "하나의 주소를 여러 기기 화면 크기로 미리 봅니다.",
  "version": "0.1.0",
  "action": {
    "default_title": "쉬운 기기 테스트 열기"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "debugger"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "scrollContentScript.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
